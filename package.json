{
  "name": "mcp-sqlite-server-advanced",
  "version": "2.0.0",
  "description": "MCP SQLite Server with LM Studio Client - Advanced Learning Project",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @mcp/shared && npm run build --workspaces",
    "typecheck": "npm run build -w @mcp/shared && npm run typecheck --workspaces",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev:server": "npm run dev -w @mcp/server",
    "dev:client": "npm run dev -w @mcp/client",
    "seed": "npm run seed -w @mcp/server",
    "start:server": "npm run start -w @mcp/server",
    "start:client": "npm run start -w @mcp/client",
    "clean": "rm -rf packages/*/dist shared/dist",
    "lint": "biome check --write",
    "lint:check": "biome check",
    "format": "biome format --write",
    "format:check": "biome format"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
